---
import SocialLink from "./SocialLink.astro";
---

<footer class="bg-dark-purple text-light">
  <div
    class="mx-auto max-w-6xl px-4 py-10 grid grid-cols-1 md:grid-cols-5 items-center gap-4 font-merriweather"
  >
    <div class="flex flex-col gap-3 col-span-2 text-center md:text-left text-sm">
      <ul class="flex flex-col gap-1">
        <li>
          <a href="/" class="text-light-gray hover:text-light transition-colors">
            Observatorio de Derecho Informático Argentino (O.D.I.A.)
          </a>
        </li>
        <li>
          <a
            href="/acerca"
            class="text-light-gray hover:text-light transition-colors"
          >
            Acerca de nosotros
          </a>
        </li>
        <li>
          <a
            href="https://marca.odia.legal"
            class="text-light-gray hover:text-light transition-colors"
          >
            Marca
          </a>
        </li>
      </ul>

      <div class="flex flex-col gap-1 text-light-gray leading-relaxed">
        <p>
          Promovemos el ejercicio responsable de la ciudadanía digital y
          garantizamos que los derechos de la comunidad sean respetados.
        </p>
        <p>CUIT: 30-71646782-8</p>
        <p>Camarones 4923, Depto. 4, C1407, Ciudad Autónoma de Buenos Aires</p>
      </div>
    </div>

    <p class="text-sm text-light-gray text-center leading-relaxed">
      <!-- TODO: mail institucional por favorrrr -->
      <a
        href="mailto:odiaasoc@gmail.com"
        class="text-light-gray hover:text-light transition-colors"
      >
        odiaasoc@gmail.com
      </a>
    </p>

    <ul
      class="flex items-center gap-3 flex-wrap justify-center md:justify-end col-span-2 text-light-gray *:hover:text-light transition-colors"
    >
      <li>
        <SocialLink
          href="https://instagram.com/odiaasoc"
          icon="mdi:instagram"
          ariaLabel="Instagram"
        />
      </li>
      <li>
        <SocialLink
          href="https://twitter.com/odiaasoc"
          icon="mdi:twitter"
          ariaLabel="Twitter"
        />
      </li>
      <li>
        <SocialLink
          href="https://www.facebook.com/ODIAasoc"
          icon="mdi:facebook"
          ariaLabel="Facebook"
        />
      </li>
      <li>
        <SocialLink
          href="https://www.linkedin.com/company/odiaasoc/"
          icon="mdi:linkedin"
          ariaLabel="LinkedIn"
        />
      </li>
      <li>
        <SocialLink
          href="https://medium.com/@odiaasoc"
          icon="mdi:medium"
          ariaLabel="Medium"
        />
      </li>
      <li>
        <SocialLink
          href="https://github.com/odia/"
          icon="mdi:github"
          ariaLabel="GitHub"
        />
      </li>
      <li>
        <SocialLink
          href="https://www.youtube.com/@observatoriodederechoinfor7762/videos"
          icon="mdi:youtube"
          ariaLabel="YouTube"
        />
      </li>
      <li>
        <SocialLink
          href="https://t.me/odiaasoc"
          icon="mdi:telegram"
          ariaLabel="Telegram"
        />
      </li>
    </ul>
  </div>
</footer>
